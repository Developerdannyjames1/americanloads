<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6.1" />
  </startup>
  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="TfmiFreightMatchingSoapBinding" />
        <binding name="TfmiFreightMatchingSoapBinding1" />
      </basicHttpBinding>
    </bindings>
    <client>
      <endpoint address="http://cnx.test.dat.com:9280/TfmiRequest"
        binding="basicHttpBinding" bindingConfiguration="TfmiFreightMatchingSoapBinding"
        contract="ServiceReference1.TfmiFreightMatchingPortType" name="TfmiFreightMatchingService" />
      <endpoint address="http://cnx.test.dat.com:9280/TfmiRequest"
        binding="basicHttpBinding" bindingConfiguration="TfmiFreightMatchingSoapBinding1"
        contract="ServiceReference1.TfmiFreightMatchingPortType" name="TfmiFreightMatchingService1" />
