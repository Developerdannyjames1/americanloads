@using TruckStopRestfullService.Models
@model TruckStopRestfullService.Models.TsResponse

@{
    ViewBag.Title = "TSLoadState";
    var removed = (List<int>)ViewBag.Removed;
}

@if (Request.IsAuthenticated && User.Identity.Name == "admin")
{
    <h2>TSLoadState</h2>

    <div class="row">
        <div class="col-md-12">
            <table class="table table-striped">
                <tr>
                    <th># / #</th>
                    <th>DestinationCountry</th>
                    <th>DestinationState</th>
                    <th>DestinationCity</th>
                    <th>OriginCountry</th>
                    <th>OriginState</th>
                    <th>OriginCity</th>
                    <th>Equipment</th>
                    <th>LoadNumber</th>
                    <th>PickupDate</th>
                </tr>
                @if (Model != null && Model.Data != null && Model.Data is List<Load> loads)
                {
                    var c = 0;
                    foreach (var load in loads)
                    {
                        var origin = load.LoadStops.FirstOrDefault(p => p.Type == 1);
                        var destin = load.LoadStops.FirstOrDefault(p => p.Type == 2);

                        c++;
                        <tr>
                            <td>@load.Text / @c</td>
                            <td>@destin.Location.CountryCode</td>
                            <td>@destin.Location.State</td>
                            <td>@destin.Location.City</td>
                            <td>@origin.Location.CountryCode</td>
                            <td>@origin.Location.State</td>
                            <td>@origin.Location.City</td>
                            <td>@load.EquipmentAttributes.EquipmentTypeId</td>
                            <td>@load.LoadNumber</td>
                            <td>@origin.EarlyDateTime</td>
                        </tr>
                        <tr>
                            <td colspan="12">
                                <div>
                                    <a class="btn btn-primary" role="button" data-toggle="collapse" href="#cl_@load.LoadId" aria-expanded="false" aria-controls="cl_@load.LoadId">
                                        Show/Hide FULL JSON
                                    </a>
                                    <div class="collapse" id="cl_@load.LoadId">
                                        <div class="well">
                                            @{
                                                var json = "";
                                                try
                                                {
                                                    json = Newtonsoft.Json.JsonConvert.SerializeObject(load, Newtonsoft.Json.Formatting.Indented);
                                                }
                                                catch
                                                {

                                                }
                                            }
    <pre>
    @Html.Raw(json)
    </pre>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                                                    }
                                                }
            </table>
            @if (ViewBag.Removed != null)
            {
                <h2>REMOVED</h2>
                <ul>
                    @foreach (var item in removed)
                    {
                        <li>@item</li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            @if (ViewBag.LastExceptions != null)
            {
                @*<p><b>Host: </b>@ASTDAT.Web.Infrastructure.IntegrationService.Instance.TruckStopUtils.Host</p>
                <p><b>UserName: </b>@ASTDAT.Web.Infrastructure.IntegrationService.Instance.TruckStopUtils.UserName</p>
                <p><b>Password: </b>@ASTDAT.Web.Infrastructure.IntegrationService.Instance.TruckStopUtils.Password</p>
                <p><b>IntegrationId: </b>@ASTDAT.Web.Infrastructure.IntegrationService.Instance.TruckStopUtils.IntegrationId</p>*@
                foreach (Tuple<DateTime, Exception> item in ViewBag.LastExceptions)
                {
                    <p>@item.Item1.ToString("yyyy-MM-dd HH:mm:ss")</p>
                    <p>@item.Item2.Message</p>
                    <p>@(item.Item2.InnerException == null ? "" : item.Item2.InnerException.Message)</p>
                    <p>@item.Item2.StackTrace</p>
                    <br />
                }
            }
            else
            {
                <p>No Exception</p>
            }
        </div>
    </div>
}