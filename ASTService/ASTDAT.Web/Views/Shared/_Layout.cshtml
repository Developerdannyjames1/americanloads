@using ASTDAT.Web.Infrastructure
<!DOCTYPE html>
<html ng-app="ASTDAT">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - AST Loads App</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <link rel="stylesheet" href="~/Libs/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/Libs/angular-toastr/dist/angular-toastr.min.css">
    <link rel="stylesheet" href="~/Content/site.css">
    <link rel="stylesheet" href="~/Libs/angular-ui-select/dist/select.min.css">

    <script src="~/Libs/jquery/dist/jquery.min.js"></script>
    <script src="~/Libs/bootstrap/dist/js/bootstrap.min.js"></script>
    <script src="~/Libs/angular/angular.js"></script>
    <script src="~/Libs/moment/min/moment-with-locales.min.js"></script>
    <script src="~/Libs/eonasdan-bootstrap-datetimepicker/build/js/bootstrap-datetimepicker.min.js"></script>

    <base href="@Url.Content("~")" />
</head>
<body>
    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                @Html.ActionLink("AST - Load board list", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
                <span style="color: white;" id="_info"></span>
            </div>
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav">
                    @if (Request.IsAuthenticated && LoadboardPermissions.ShouldUseCarrierPortal(User))
                    {
                        <li>@Html.ActionLink("Carrier portal", "Index", "Carrier", new { area = "" }, new { })</li>
                    }
                </ul>
                @Html.Partial("_LoginPartial")
            </div>
        </div>
    </div>
    <div class="container-fluid body-content" style="margin-left: auto !important; margin-right: auto !important; max-width: 1320px; width: 100%; padding-left: 12px; padding-right: 12px;">
        <div ng-show="globalLoading" class="sk-cube-grid" title="Query in progress">
            <div class="sk-cube sk-cube1"></div>
            <div class="sk-cube sk-cube2"></div>
            <div class="sk-cube sk-cube3"></div>
            <div class="sk-cube sk-cube4"></div>
            <div class="sk-cube sk-cube5"></div>
            <div class="sk-cube sk-cube6"></div>
            <div class="sk-cube sk-cube7"></div>
            <div class="sk-cube sk-cube8"></div>
            <div class="sk-cube sk-cube9"></div>
        </div>

        @RenderBody()
        <hr />
        <footer>
            <p style="margin-bottom: 0px;">&copy; 2019 - AST, American Specialized Transport</p>
        </footer>
    </div>

    @RenderSection("scripts", required: false)

   <link rel="stylesheet" href="~/Libs/angucomplete-alt/angucomplete-alt.css">

    @*
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script src="~/Libs/bootstrap/dist/js/bootstrap.min.js"></script>
    *@
    <script src="~/Libs/jqueri-ui/jquery-ui.min.js"></script>
    <script src="~/Libs/angular-animate/angular-animate.min.js"></script>
    <script src="~/Libs/angular-resource/angular-resource.min.js"></script>
    <script src="~/Libs/angular-messages/angular-messages.min.js"></script>
    <script src="~/Libs/angular-moment/angular-moment.min.js"></script>
    <script src="~/Libs/angular-bootstrap/ui-bootstrap-tpls.min.js"></script>
    <script src="~/Libs/angular-sanitize/angular-sanitize.min.js"></script>
    <script src="~/Libs/angular-bootstrap-datetimepicker-directive/angular-bootstrap-datetimepicker-directive.min.js"></script>
    <script src="~/Libs/ngBootbox/dist/ngBootbox.min.js"></script>
    <script src="~/Libs/angular-toastr/dist/angular-toastr.tpls.min.js"></script>
    <script src="~/Libs/angucomplete-alt/dist/angucomplete-alt.min.js"></script>
    <script src="~/Libs/angular-filter/dist/angular-filter.min.js"></script>
    <script src="~/Libs/angular-ui-select/dist/select.min.js"></script>

    <script src="~/Libs/bootbox/bootbox.js"></script>

    <script src="~/Scripts/angular-ase.com.ua.js"></script>
    <script src="~/Scripts/dis.js?version=@System.Reflection.Assembly.GetAssembly(typeof(ASTDAT.Web.Startup)).GetName().Version"></script>
    <script>
        $(function () {
            //$('#_info').html('width: ' + window.innerWidth);
        });
    </script>
</body>
</html>
