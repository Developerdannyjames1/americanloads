@{
    ViewBag.Title = "Carrier portal";
}
<div class="row" style="margin-top:8px;">
    <div class="col-md-12">
        <h2 style="margin-top:0;">Carrier portal</h2>
        <p class="text-muted">Search posted loads, view details, claim, or place a bid. (Approved carrier accounts only.)</p>
    </div>
</div>
<div class="row" style="margin-bottom:12px;">
    <div class="col-md-3 col-sm-6" style="margin-bottom:8px;">
        <label>Location (city / lane)</label>
        <input type="text" id="cp-lane" class="form-control" placeholder="Origin or destination" />
    </div>
    <div class="col-md-3 col-sm-6" style="margin-bottom:8px;">
        <label>Equipment</label>
        <input type="text" id="cp-equip" class="form-control" placeholder="e.g. Van" />
    </div>
    <div class="col-md-2 col-sm-6" style="margin-bottom:8px;">
        <label>From</label>
        <input type="date" id="cp-df" class="form-control" />
    </div>
    <div class="col-md-2 col-sm-6" style="margin-bottom:8px;">
        <label>To</label>
        <input type="date" id="cp-dt" class="form-control" />
        <small class="text-muted" style="display:block;">(Filters by create date, same as main board.)</small>
    </div>
    <div class="col-md-2" style="margin-bottom:8px; padding-top:24px;">
        <div class="row">
            <div class="col-xs-6" style="padding-right:4px;">
                <button type="button" class="btn btn-primary btn-block" id="cp-search" onclick="if(window.carrierPortalSearch){window.carrierPortalSearch();}">Search</button>
            </div>
            <div class="col-xs-6" style="padding-left:4px;">
                <button type="button" class="btn btn-info btn-block" id="cp-clear" style="background-color: darkturquoise;"
                        onclick="var a=document.getElementById('cp-lane'); if(a){a.value='';} var b=document.getElementById('cp-equip'); if(b){b.value='';} var c=document.getElementById('cp-df'); if(c){c.value='';} var d=document.getElementById('cp-dt'); if(d){d.value='';} if(window.carrierPortalSearch){window.carrierPortalSearch();} else { var s=document.getElementById('cp-search'); if(s){s.click();} }">Clear</button>
            </div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-md-7">
        <div id="cp-err" class="alert alert-danger" style="display:none;"></div>
        <div class="table-responsive" style="max-height:60vh; overflow:auto;">
            <table class="table table-striped table-condensed" id="cp-tbl">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Lane</th>
                        <th>Eq.</th>
                        <th>Status</th>
                        <th>Pickup</th>
                    </tr>
                </thead>
                <tbody id="cp-tbody"></tbody>
            </table>
        </div>
    </div>
    <div class="col-md-5">
        <h4>Details</h4>
        <div id="cp-detail" class="well well-sm" style="min-height:200px; white-space:pre-wrap; font-size:13px;">Select a load…</div>
        <div id="cp-actions" style="display:none; margin-top:8px;">
            <button type="button" class="btn btn-success" id="cp-claim">Claim load</button>
            <button type="button" class="btn btn-info" id="cp-bid">Submit bid</button>
        </div>
        <div id="cp-events" class="text-muted" style="margin-top:12px; font-size:12px;">Events: <span id="cp-evlast">—</span></div>
    </div>
</div>
@section scripts {
    <script src="~/Scripts/carrier-portal.js"></script>
}
